rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /teams/{teamId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.memberIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.memberIds;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.memberIds;
    }
    match /teams/{teamId}/expenses/{expenseId} {
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/teams/$(teamId)).data.memberIds.hasAny([request.auth.uid]);
    }
  }
}
