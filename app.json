{
  "expo": {
    "name": "Team Split",
    "slug": "TeamSplit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dev.teamsplit",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "TeamSplit needs access to your photo library so you can choose a profile picture.",
        "NSCameraUsageDescription": "TeamSplit needs camera access to take a profile picture.",
        "NSPhotoLibraryAddUsageDescription": "TeamSplit needs permission to save photos to your library."
      }
    },
    "android": {
      "package": "com.dev.teamsplit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "db46643f-8135-42de-b842-5b8e9a1d4c73"
      }
    },
    "owner": "shoaib.dev"
  }
}
